#!/bin/bash
set -e

# Rust: format
cargo fmt --quiet

# Frontend: lint-staged (eslint --fix + prettier --write on staged files)
cd apps/ui && npx lint-staged
cd "$OLDPWD"

# Re-stage formatted files
git diff --name-only | xargs -r git add

# Rust: lint (warnings = errors)
cargo clippy --workspace -- -D warnings 2>/dev/null

# TypeScript: type check
(cd apps/ui && npx tsc --noEmit 2>&1 | head -5)

echo "pre-commit: all checks passed"
