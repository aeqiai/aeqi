#!/usr/bin/env bash
# Pre-push gate — runs scripts/ci-local.sh before each `git push`.
# Bypass for emergencies (e.g. pushing a docs-only typo fix): `git push --no-verify`.
#
# Enable once per checkout:
#   git config core.hooksPath .githooks

exec "$(git rev-parse --show-toplevel)/scripts/ci-local.sh"
