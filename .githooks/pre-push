#!/usr/bin/env bash
# Compatibility pre-push gate. The installed hook path is scripts/git-hooks;
# this wrapper remains for older checkouts that still point core.hooksPath at
# .githooks.
# Bypass for emergencies (e.g. pushing a docs-only typo fix): `git push --no-verify`.
#
# Preferred install:
#   scripts/install-git-hooks.sh

exec "$(git rev-parse --show-toplevel)/scripts/ci-local.sh" prepush
