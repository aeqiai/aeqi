#!/bin/bash
# Auto-reindex code graph after every commit.
# Runs in background so commits aren't slowed down.
# Works in all worktrees (core.hooksPath is shared).

AEQI_BIN="${AEQI_BIN:-/home/claudedev/aeqi/target/release/aeqi}"
AEQI_CONFIG="${AEQI_CONFIG:-/var/lib/aeqi/hosts/luca-eich/aeqi.toml}"

[ -x "$AEQI_BIN" ] || exit 0

AEQI_CONFIG="$AEQI_CONFIG" "$AEQI_BIN" code incremental --project luca-eich &>/dev/null &
