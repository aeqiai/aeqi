# Example local env. Copy to `.env` (or `.env.local`) before `npm run dev`.
# Vite only exposes vars prefixed with `VITE_` to the browser bundle.

# Solana RPC endpoint used by `@/solana` reads. Defaults to the localnet
# validator port declared in `projects/aeqi-solana/Anchor.toml` when unset;
# set to a mainnet RPC for mainnet flip.
VITE_SOLANA_RPC_URL=http://127.0.0.1:9120
