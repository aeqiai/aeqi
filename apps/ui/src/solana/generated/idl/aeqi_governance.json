              {
                "kind": "account",
                "path": "proposal.trust",
                "account": "Proposal"
              },
              {
                "kind": "account",
                "path": "proposal.proposal_id",
                "account": "Proposal"
              }
            ]
          }
        },
        {
          "name": "committer",
          "docs": [
            "Permissionless caller — the snapshot job pays rent for the tx and",
            "the program enforces one-shot via `proposal.snapshot_root == [0; 32]`."
          ],
          "signer": true
        }
