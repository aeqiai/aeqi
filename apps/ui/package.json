{
  "name": "aeqi-ui",
  "description": "Web control plane for the AEQI agent runtime",
  "private": true,
  "version": "0.8.0",
  "license": "MIT",
  "author": "aeqixyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/aeqi-ai/aeqi/tree/main/apps/ui"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "dev:prod-api": "AEQI_UI_API_PROXY_TARGET=https://app.aeqi.ai vite",
    "build": "npm run typecheck && npm run bundle",
    "bundle": "vite build",
    "build:analyze": "ANALYZE=1 vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,mdx}\"",
    "check": "npm run typecheck && npm run format:check",
    "hygiene": "node scripts/hygiene-check.mjs",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "design-system:audit": "node scripts/design-system-audit.mjs",
    "design-system:update-baseline": "node scripts/design-system-audit.mjs --update-baseline",
    "perf:check": "node scripts/perf-baseline.mjs",
    "perf:update-baseline": "node scripts/perf-baseline.mjs --update-baseline",
    "verify-url-contract": "node scripts/verify-url-contract.mjs",
    "verify": "node ../../scripts/ui-verify-stamp.mjs --clear && npm run check && npm run lint && npm run test && npm run hygiene && npm run design-system:audit && npm run i18n:audit && npm run build && node ../../scripts/ui-verify-stamp.mjs --write",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,mdx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "cd ../.. && ./apps/ui/node_modules/.bin/husky 2>/dev/null || true"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@blocknote/core": "^0.50.0",
    "@blocknote/mantine": "^0.50.0",
    "@blocknote/react": "^0.50.0",
    "@coral-xyz/anchor": "^0.31.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@simplewebauthn/browser": "^13.3.0",
    "@solana/web3.js": "^1.95.0",
    "@tanstack/react-query": "^5.100.10",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/qrcode": "^1.5.6",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "lucide-react": "^0.460.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "viem": "^2.48.11",
    "wagmi": "^2.19.5",
    "web-vitals": "^5.0.0",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "axios": "1.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@storybook/addon-a11y": "^8.0.0",
    "@storybook/addon-backgrounds": "^8.6.18",
    "@storybook/addon-controls": "^8.6.18",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-highlight": "^8.6.18",
    "@storybook/addon-measure": "^8.6.18",
    "@storybook/addon-outline": "^8.6.18",
    "@storybook/addon-toolbars": "^8.6.18",
    "@storybook/addon-viewport": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "storybook": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
