{
  "name": "aeqi",
  "description": "Agent runtime, multi-agent harness, orchestration engine, and web control plane",
  "private": true,
  "scripts": {
    "ui:install": "npm --prefix apps/ui ci",
    "ui:dev": "npm --prefix apps/ui run dev",
    "ui:build": "npm --prefix apps/ui run build",
    "ui:preview": "npm --prefix apps/ui run preview",
    "dev:triage": "scripts/dev-triage.sh",
    "deploy:webhook": "scripts/webhook-deploy-aeqi.sh",
    "visual:route": "node scripts/visual-route.mjs",
    "solana:build": "cd projects/aeqi-solana && anchor build",
    "solana:test": "cd projects/aeqi-solana && anchor test --skip-build"
  },
  "devDependencies": {
    "playwright": "^1.52.0"
  }
}
