{
  "name": "aeqi",
  "description": "Agent runtime, multi-agent harness, orchestration engine, and web control plane",
  "private": true,
  "scripts": {
    "surface:catalog": "node scripts/repo-surface-catalog.mjs",
    "surface:catalog:write": "node scripts/repo-surface-catalog.mjs --write",
    "surface:catalog:check": "node scripts/repo-surface-catalog.mjs --check",
    "maintainability:ratchet": "node scripts/maintainability-ratchet.mjs",
    "maintainability:report": "node scripts/maintainability-ratchet.mjs --report",
    "maintainability:update-baseline": "node scripts/maintainability-ratchet.mjs --update-baseline",
    "ui:install": "npm --prefix apps/ui ci",
    "ui:dev": "npm --prefix apps/ui run dev",
    "ui:dev:prod-api": "npm --prefix apps/ui run dev:prod-api",
    "ui:build": "npm --prefix apps/ui run build",
    "ui:preview": "npm --prefix apps/ui run preview",
    "dev:triage": "scripts/dev-triage.sh",
    "deploy:webhook": "scripts/webhook-deploy-aeqi.sh",
    "ui:wt": "scripts/ui-worktree.sh",
    "visual:check": "node scripts/visual-check.mjs",
    "visual:check:list": "node scripts/visual-check.mjs --list",
    "visual:route": "node scripts/visual-route.mjs",
    "browser:capture": "node scripts/browser-capture.mjs",
    "rehearsal:browser-evidence": "node scripts/operator-rehearsal-browser-evidence.mjs",
    "launch:smoke": "node scripts/launch-smoke.mjs",
    "solana:build": "cd projects/aeqi-solana && anchor build",
    "solana:test": "cd projects/aeqi-solana && anchor test --skip-build"
  },
  "devDependencies": {
    "playwright": "^1.52.0"
  }
}
