{
  "name": "aeqi-solana",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "build": "anchor build",
    "test": "anchor test",
    "test:mocha": "npx ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "test:anchor": "anchor test",
    "test:anchor:skip-build": "anchor test --skip-build",
    "test:rust": "cargo test -q --workspace --lib",
    "typecheck": "npm run typecheck:generated",
    "typecheck:generated": "anchor build && npm run typecheck:ts",
    "typecheck:ts": "tsc --noEmit",
    "bootstrap:templates": "ts-node scripts/bootstrap-templates.ts",
    "verify:ci": "npm run fmt:rs:check && npm run test:rust && npm run lint:rs:strict && npm run typecheck:generated && npm run lint",
    "build:verify": "anchor build && npm run verify:hashes",
    "verify:hashes": "node scripts/verify-program-hashes.mjs",
    "fmt:rs": "cargo fmt --all",
    "fmt:rs:check": "cargo fmt --all --check",
    "cov:rs": "cargo llvm-cov --workspace --lcov --output-path target/coverage/lcov.info",
    "cov:rs:html": "cargo llvm-cov --workspace --html --output-dir target/coverage/html",
    "cov:rs:summary": "cargo llvm-cov --workspace --summary-only",
    "lint:rs": "cargo clippy --all-targets --all-features",
    "lint:rs:strict": "cargo clippy --all-targets --all-features -- -D warnings",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.12",
    "@types/mocha": "^10.0.6",
    "chai": "^4.4.1",
    "mocha": "^10.4.0",
    "prettier": "^3.0.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
